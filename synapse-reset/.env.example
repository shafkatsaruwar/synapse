# Copy this file to .env and fill in your values.
# For local dev: keep .env out of git (it's in .gitignore).
# For EAS Build: either set these in Expo project → Environment variables, OR
# copy to .env, fill in, and commit .env so the build has them (Supabase anon key is public).

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard
