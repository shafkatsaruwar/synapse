# Copy this file to .env and fill in your values.
# For EAS Build / physical device: set EXPO_PUBLIC_API_URL or EXPO_PUBLIC_APP_URL so the app
# does not use localhost (device cannot reach your machine). Use your deployed API URL (https).

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard
EXPO_PUBLIC_APP_URL=https://your-app.vercel.app
# Backend API base URL (document scan, insights, email). Can be same as APP_URL if API lives there.
EXPO_PUBLIC_API_URL=https://your-api.vercel.app
