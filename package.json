{
  "name": "expo-app",
  "version": "1.0.0",
  "scripts": {
    "eas-build-pre-install": "bash ./scripts/eas-pre-install.sh",
    "postinstall": "patch-package",
    "expo:dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost",
    "server:dev": "NODE_ENV=development tsx server/index.ts",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "web:build": "cd synapse-reset && npm run export:web",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "db:push": "drizzle-kit push",
    "start": "cd synapse-reset && npm run start",
    "start:go": "cd synapse-reset && npx expo start --go",
    "web": "cd synapse-reset && npm run web",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "android": "cd synapse-reset && npm run android",
    "ios": "cd synapse-reset && npm run ios"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.83.0",
    "@ungap/structured-clone": "^1.3.0",
    "crypto-es": "^3.1.2",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.1",
    "expo": "~54.0.27",
    "expo-blur": "~15.0.8",
    "expo-camera": "~16.0.14",
    "expo-constants": "~18.0.11",
    "expo-crypto": "^15.0.8",
    "expo-font": "~14.0.10",
    "expo-http-server": "^0.1.13",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-network": "~7.0.3",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "^14.0.8",
    "expo-speech": "^14.0.8",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.0.1",
    "http-proxy-middleware": "^3.0.5",
    "openai": "^6.22.0",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "pg": "^8.16.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-qrcode-svg": "^6.3.2",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0",
    "resend": "^6.9.2",
    "tsx": "^4.20.6",
    "ws": "^8.18.0",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.0",
    "@types/express": "^5.0.0",
    "@types/react": "~19.1.10",
    "@vercel/node": "^5.6.7",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~10.0.0",
    "patch-package": "^8.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
